rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: get the calling user's role
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Users collection
    match /users/{userId} {
      // Any authenticated user can read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;
      // Any authenticated user can create/update their own profile
      allow write: if request.auth != null && request.auth.uid == userId;
      // Owner can read all staff profiles (for Settings page)
      allow read, write: if request.auth != null && userRole() == 'owner';
    }

    // All operational collections — any signed-in user can read/write
    // (fine-grained role enforcement is done in the frontend)
    match /tables/{doc} {
      allow read, write: if request.auth != null;
    }
    match /orders/{doc} {
      allow read, write: if request.auth != null;
    }
    match /menu/{doc} {
      allow read, write: if request.auth != null;
    }
    match /customers/{doc} {
      allow read, write: if request.auth != null;
    }
    match /payments/{doc} {
      allow read, write: if request.auth != null;
    }
    match /inventory/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
